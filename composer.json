{
    "name": "ultrono/laravel-sitemap",
    "description": "Sitemap generator for Laravel 11, 12 and 13",
    "keywords": ["laravel", "php", "sitemap", "generator", "xml", "html", "google-news"],
    "license": "MIT",
    "authors": [
        {
            "name": "Rumen Damyanov",
            "email": "r@alfamatter.com",
            "role": "Original Developer",
            "homepage": "https://darumen.com"
        },
        {
            "name": "Rob Allport",
            "email": "rob@f9web.co.uk",
            "role": "Developer",
            "homepage": "https://f9web.co.uk"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "illuminate/filesystem": "^11.0|^12.0|^13.0"
    },
        "require-dev": {
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "phpunit/phpunit": "^11.5.3|^12.5.8"
    },
    "autoload": {
        "psr-0": {
            "Ultrono\\Sitemap": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Ultrono\\Sitemap\\SitemapServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
